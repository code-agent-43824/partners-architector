# psa application/runtime configuration.
#
# Copy this file to deploy/.env and fill in real values. deploy/.env is
# git-ignored and must never be committed. Phase 0 step 0.2 uses the
# PostgreSQL settings; later steps consume the rest.

# --- PostgreSQL (db service) ---
POSTGRES_USER=psa
# Required: set a strong value in deploy/.env (no default is provided on purpose).
POSTGRES_PASSWORD=
POSTGRES_DB=psa
# Host port mapped to the container's 5432.
DB_PORT=5432

# --- API (wired up in step 0.3) ---
# Inside Compose the API reaches the db at host "db". When running the API on
# your host against the Compose database, use localhost:${DB_PORT} instead:
#   postgresql://psa:<password>@localhost:5432/psa
DATABASE_URL=postgresql://psa:@localhost:5432/psa
API_PORT=3000

# --- Auth (step 0.6; SEC-1) ---
# Generate a long random value, e.g. `openssl rand -hex 32`.
AUTH_JWT_SECRET=
AUTH_TOKEN_TTL=7d
# Set true when served over HTTPS (production behind the TLS proxy).
AUTH_COOKIE_SECURE=false
# Optional: bootstrap an initial admin on first boot if no admin exists.
AUTH_ADMIN_EMAIL=
AUTH_ADMIN_PASSWORD=
# Optional: when set, POST /auth/register requires this shared code.
# AUTH_REGISTRATION_CODE=

# --- Web (wired up in step 0.7) ---
WEB_PORT=8080

# --- Self-hosted AI (Phases 7-8; not used yet) ---
# Self-hosted, OpenAI-compatible endpoint only — no third-party clouds (SEC-4).
# INFERENCE_BASE_URL=
# LLM_MODEL=
